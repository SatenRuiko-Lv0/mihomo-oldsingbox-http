From: SatenRuiko-Lv0 <pcscgxy@qq.com>
Date: Tue, 16 Jun 2026 12:23:43 +0800
Subject: [PATCH 2/3] Match legacy VMess HTTP request shape


diff --git a/transport/vmess/http.go b/transport/vmess/http.go
index e1351468..439b17b8 100644
--- a/transport/vmess/http.go
+++ b/transport/vmess/http.go
@@ -6,9 +6,8 @@ import (
 	"io"
 	"net"
 	"net/textproto"
-	"net/url"
+	"strings"
 
-	"github.com/metacubex/http"
 	"github.com/metacubex/randv2"
 )
 
@@ -58,23 +57,12 @@ func (hc *httpConn) Write(b []byte) (int, error) {
 		path = hc.cfg.Path[randv2.IntN(len(hc.cfg.Path))]
 	}
 
-	host := hc.cfg.Host
-	if header := hc.cfg.Headers["Host"]; len(header) != 0 {
-		host = header[randv2.IntN(len(header))]
+	method := hc.cfg.Method
+	if method == "" {
+		method = "PUT"
 	}
-
-	req := http.Request{
-		Method: hc.cfg.Method, // default is GET
-		Host:   host,
-		URL:    &url.URL{Scheme: "http", Host: host, Path: path},
-		Header: make(http.Header),
-		Body:   io.NopCloser(bytes.NewReader(b)),
-	}
-	for key, list := range hc.cfg.Headers {
-		req.Header.Set(key, list[randv2.IntN(len(list))])
-	}
-	req.ContentLength = int64(len(b))
-	if err := req.Write(hc.Conn); err != nil {
+	host := pickHTTPHeader(hc.cfg.Host, hc.cfg.Headers, "Host")
+	if err := writeHTTPClientRequest(hc.Conn, method, path, host, hc.cfg.Headers, b); err != nil {
 		return 0, err
 	}
 	hc.whandshake = true
@@ -91,3 +79,48 @@ func StreamHTTPConn(conn net.Conn, cfg *HTTPConfig) net.Conn {
 		cfg:  cfg,
 	}
 }
+
+func writeHTTPClientRequest(conn net.Conn, method string, path string, host string, headers map[string][]string, payload []byte) error {
+	if path == "" {
+		path = "/"
+	}
+	if !strings.HasPrefix(path, "/") {
+		path = "/" + path
+	}
+
+	var buffer bytes.Buffer
+	buffer.WriteString(method)
+	buffer.WriteByte(' ')
+	buffer.WriteString(path)
+	buffer.WriteString(" HTTP/1.1\r\n")
+	buffer.WriteString("Host: ")
+	buffer.WriteString(host)
+	buffer.WriteString("\r\n")
+
+	for key, values := range headers {
+		if strings.EqualFold(key, "Host") || len(values) == 0 {
+			continue
+		}
+		buffer.WriteString(key)
+		buffer.WriteString(": ")
+		buffer.WriteString(values[randv2.IntN(len(values))])
+		buffer.WriteString("\r\n")
+	}
+
+	buffer.WriteString("\r\n")
+	buffer.Write(payload)
+	n, err := conn.Write(buffer.Bytes())
+	if err == nil && n != buffer.Len() {
+		err = io.ErrShortWrite
+	}
+	return err
+}
+
+func pickHTTPHeader(fallback string, headers map[string][]string, name string) string {
+	for key, values := range headers {
+		if strings.EqualFold(key, name) && len(values) > 0 {
+			return values[randv2.IntN(len(values))]
+		}
+	}
+	return fallback
+}
diff --git a/transport/vmess/http_test.go b/transport/vmess/http_test.go
new file mode 100644
index 00000000..4f05fd92
--- /dev/null
+++ b/transport/vmess/http_test.go
@@ -0,0 +1,62 @@
+package vmess
+
+import (
+	"strings"
+	"testing"
+)
+
+func TestWriteHTTPClientRequestLegacyDefault(t *testing.T) {
+	conn := &captureConn{}
+	payload := []byte("vmess-payload")
+
+	err := writeHTTPClientRequest(conn, "PUT", "/", "tms.dingtalk.com", nil, payload)
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	expected := strings.Join([]string{
+		"PUT / HTTP/1.1",
+		"Host: tms.dingtalk.com",
+		"",
+		"vmess-payload",
+	}, "\r\n")
+
+	actual := conn.written.String()
+	if actual != expected {
+		t.Fatalf("unexpected request:\n%s", actual)
+	}
+	if strings.Contains(actual, "Content-Length:") {
+		t.Fatal("request should not include Content-Length")
+	}
+}
+
+func TestWriteHTTPClientRequestPreservesConfiguredHeaders(t *testing.T) {
+	conn := &captureConn{}
+	payload := []byte("body")
+
+	err := writeHTTPClientRequest(conn, "GET", "/path", "example.com", map[string][]string{
+		"Host":       {"example.com"},
+		"User-Agent": {"Go-http-client/1.1"},
+		"Connection": {"keep-alive"},
+	}, payload)
+	if err != nil {
+		t.Fatal(err)
+	}
+
+	actual := conn.written.String()
+	if !strings.HasPrefix(actual, "GET /path HTTP/1.1\r\nHost: example.com\r\n") {
+		t.Fatalf("unexpected prefix:\n%s", actual)
+	}
+	if !strings.Contains(actual, "\r\nUser-Agent: Go-http-client/1.1\r\n") {
+		t.Fatalf("missing user-agent:\n%s", actual)
+	}
+	if !strings.Contains(actual, "\r\nConnection: keep-alive\r\n") {
+		t.Fatalf("missing connection:\n%s", actual)
+	}
+	if !strings.HasSuffix(actual, "\r\n\r\nbody") {
+		t.Fatalf("payload is not appended after headers:\n%s", actual)
+	}
+	if strings.Contains(actual, "Content-Length:") {
+		t.Fatal("request should not include Content-Length")
+	}
+}
